# Database
# Local (Docker): postgresql://postgres:postgres@localhost:5432/billchill
# Supabase (production): postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/billchill

# Auth0 (v4 SDK)
AUTH0_SECRET= # openssl rand -hex 32
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://[YOUR-TENANT].auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Auth0 v4 uses these env vars automatically:
# AUTH0_SECRET - used to encrypt session cookies
# AUTH0_BASE_URL - your app's base URL
# AUTH0_ISSUER_BASE_URL - your Auth0 domain (https://xxx.auth0.com)
# AUTH0_CLIENT_ID - Auth0 application client ID
# AUTH0_CLIENT_SECRET - Auth0 application client secret
